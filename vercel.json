{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.6.0"
        }
    },
    "routes": [
        {
            "src": "/(build|img|assets|favicon.ico|robots.txt)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:xJ3Nhko4hNRN/KOaFOM6cVx2oyRiVc3mvbqcuJkxG5I=",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_STORE": "array",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "SESSION_STORE": "array",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "null"
    }
}
